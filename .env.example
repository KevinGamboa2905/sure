# ─────────────────────────────────────────────────────────────
# TableSure — Variables d'environnement
# Copiez ce fichier en .env.local puis renseignez vos valeurs.
# ─────────────────────────────────────────────────────────────

# Stripe Platform (compte TableSure)
# Récupérez ces clés sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Stripe Connect (https://dashboard.stripe.com/settings/connect)
STRIPE_CONNECT_CLIENT_ID=ca_xxxxx

# Webhook (https://dashboard.stripe.com/webhooks) — secret de signature
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Mode démo : "true" (ou absent) = simulation locale, aucun appel Stripe.
# Passez à "false" pour activer la vraie intégration (clés ci-dessus requises).
NEXT_PUBLIC_STRIPE_DEMO_MODE=true

# URL de base de l'application
NEXT_PUBLIC_APP_URL=http://localhost:3000
